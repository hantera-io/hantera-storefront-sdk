{
  "name": "@hantera/storefront-sdk",
  "version": "0.1.0",
  "description": "Hantera Storefront SDK — cart and checkout for headless storefronts",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./cart": {
      "import": "./dist/cart/index.js",
      "require": "./dist/cart/index.cjs",
      "types": "./dist/cart/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.4"
  },
  "license": "Apache-2.0",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/hantera-io/hantera-storefront-sdk.git",
    "directory": "packages/storefront-sdk"
  },
  "homepage": "https://storefront.hantera.dev",
  "bugs": {
    "url": "https://github.com/hantera-io/hantera-storefront-sdk/issues"
  }
}
